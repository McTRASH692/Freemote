<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================================
     FILE: ic_remote_control.xml
     WHAT:  App launcher icon / remote body — a trapezoid shape resembling a
            TV remote control, with a D-pad and channel buttons.
     ============================================================================ -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Remote body outline (trapezoid, wider at top) -->
    <path android:fillColor="@android:color/transparent" android:strokeColor="?attr/colorButtonIcon" android:strokeWidth="2" android:strokeLineJoin="round" android:pathData="M5 4L19 3L20 18L6 19Z"/>
    <!-- D-pad left arrow (triangle pointing left) -->
    <path android:fillColor="@android:color/transparent" android:strokeColor="?attr/colorButtonIcon" android:strokeWidth="2" android:strokeLineCap="round" android:strokeLineJoin="round" android:pathData="M8 9L13 11L8 13Z"/>
    <!-- Left channel button (vertical line with arrow tip) -->
    <path android:fillColor="@android:color/transparent" android:strokeColor="?attr/colorButtonIcon" android:strokeWidth="1.5" android:strokeLineCap="round" android:pathData="M15.5 14.5L15.5 11"/>
    <path android:fillColor="@android:color/transparent" android:strokeColor="?attr/colorButtonIcon" android:strokeWidth="1.5" android:strokeLineCap="round" android:pathData="M15.5 11C15.5 11 17 11 17 12"/>
    <path android:fillColor="?attr/colorButtonIcon" android:pathData="M15 14.5L15.5 14L16 14.5L15.5 15Z"/>
    <!-- Right channel button (vertical line with arrow tip) -->
    <path android:fillColor="@android:color/transparent" android:strokeColor="?attr/colorButtonIcon" android:strokeWidth="1.5" android:strokeLineCap="round" android:pathData="M18.5 15.5L18.5 12"/>
    <path android:fillColor="@android:color/transparent" android:strokeColor="?attr/colorButtonIcon" android:strokeWidth="1.5" android:strokeLineCap="round" android:pathData="M18.5 12C18.5 12 20 12 20 13"/>
    <path android:fillColor="?attr/colorButtonIcon" android:pathData="M18 15.5L18.5 15L19 15.5L18.5 16Z"/>
</vector>
