<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================================
     FILE: ic_123.xml
     WHAT:  Number input button — the digits "1", "2", and "3" stacked
            vertically. Used on a remote-control number pad.
     ============================================================================ -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Digit "1" at the top -->
    <path android:fillColor="@android:color/transparent" android:strokeColor="?attr/colorButtonIcon" android:strokeWidth="2" android:strokeLineCap="round" android:strokeLineJoin="round" android:pathData="M11 3L11 8M9 3.5h4"/>
    <!-- Digit "2" in the middle — curves down like a swan -->
    <path android:fillColor="@android:color/transparent" android:strokeColor="?attr/colorButtonIcon" android:strokeWidth="2" android:strokeLineCap="round" android:strokeLineJoin="round" android:pathData="M8 10C14 10 14 13 8 14L14 16"/>
    <!-- Digit "3" at the bottom — two stacked curves -->
    <path android:fillColor="@android:color/transparent" android:strokeColor="?attr/colorButtonIcon" android:strokeWidth="2" android:strokeLineCap="round" android:strokeLineJoin="round" android:pathData="M8 18C14 18 14 20 8 20C14 20 14 22 8 22"/>
</vector>
