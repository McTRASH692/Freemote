<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================================
     FILE: bg_nav_zone.xml
     WHAT:  Navigation zone background — a rounded rectangle with a distinct
            fill and thin border. Highlights the directional pad / navigation
            area on the remote, visually separating it from other buttons.
     ============================================================================ -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="?attr/colorNavZone" />
    <stroke android:width="1dp" android:color="?attr/colorPrimary" />
    <corners android:radius="12dp" />
</shape>
