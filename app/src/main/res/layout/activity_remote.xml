<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================================
     FILE: activity_remote.xml
     WHAT:  The main remote control screen layout. This defines all the buttons
            and controls the user interacts with to control their TV:
            - Power, Info, Guide, Menu buttons
            - Volume controls (up/down/mute)
            - Navigation: D-pad mode OR touchpad mode (switchable)
            - Channel controls (up/down/entry)
            - Back, Home, Source buttons
            - App shortcut buttons (2 rows of 3)
            - Apps, Cast, Keyboard utility buttons
            - Media transport controls (play/pause, prev/next, rewind/FF)
            - Hidden EditText for soft keyboard input
     ============================================================================ -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollViewRemote"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ==================================================================
             Hidden keyboard input field
             WHAT:  An invisible text box that catches typed text from the
                    soft keyboard. When the keyboard button is pressed, this
                    field becomes visible and focused, the soft keyboard opens,
                    and every keystroke is sent in real-time to the TV.
             WHY:   Android requires a focused EditText to show the keyboard.
                    We hide this one so it doesn't take up visual space.
             ================================================================== -->
        <EditText
            android:id="@+id/hiddenKeyboardInput"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:inputType="textNoSuggestions|textVisiblePassword"
            android:imeOptions="flagNoExtractUi|flagNoFullscreen"
            android:background="@null"
            android:textSize="1sp" />

        <!-- ==================================================================
             Row 1: Power | Device Name & Status | Settings
             ================================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:id="@+id/btnPower"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_button"
                android:src="@drawable/ic_power"
                android:padding="12dp"
                android:contentDescription="Power" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginHorizontal="8dp">

                <TextView
                    android:id="@+id/tvDeviceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No device"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvConnectionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Connecting..."
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="10sp"
                    android:gravity="center" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_button"
                android:src="@drawable/ic_settings"
                android:padding="12dp"
                android:contentDescription="Settings" />

        </LinearLayout>

        <!-- ==================================================================
             Row 2: Info | Guide | Menu
             ================================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:id="@+id/btnInfo"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button"
                android:src="@drawable/ic_info"
                android:padding="12dp"
                android:contentDescription="Info"
                android:layout_marginEnd="6dp" />

            <ImageButton
                android:id="@+id/btnGuide"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button"
                android:src="@drawable/ic_grid_2x2"
                android:padding="12dp"
                android:contentDescription="Guide"
                android:layout_marginEnd="6dp" />

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button"
                android:src="@drawable/ic_menu"
                android:padding="12dp"
                android:contentDescription="Menu" />

        </LinearLayout>

        <!-- ==================================================================
             Nav Zone: Vol | D-pad/Touchpad/Media | CH
             The center area switches between D-pad, Touchpad, and Media
             control modes. The three panels (layoutDpadPanel, layoutTouchPanel,
             layoutMediaPanel) are stacked in a FrameLayout and each is shown
             or hidden depending on the current mode.
             ================================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_nav_zone"
            android:padding="8dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Left column: Volume (dpad/media) / Mouse buttons (touchpad) -->
            <FrameLayout
                android:id="@+id/layoutLeftSide"
                android:layout_width="52dp"
                android:layout_height="match_parent">

                <!-- Volume buttons: Vol Up | Vol Down | Mute -->
                <LinearLayout
                    android:id="@+id/layoutVolColumn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:visibility="visible">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <ImageButton
                        android:id="@+id/btnVolUp"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_button"
                        android:src="@drawable/ic_volume_2"
                        android:padding="10dp"
                        android:contentDescription="Volume Up" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VOL"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <ImageButton
                        android:id="@+id/btnVolDown"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_button"
                        android:src="@drawable/ic_volume_1"
                        android:padding="10dp"
                        android:contentDescription="Volume Down" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <ImageButton
                        android:id="@+id/btnMute"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_button"
                        android:src="@drawable/ic_volume_x"
                        android:padding="10dp"
                        android:contentDescription="Mute" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                </LinearLayout>                <!-- Mouse buttons: R | M | L (shown in touchpad mode) -->
                <LinearLayout
                    android:id="@+id/layoutMouseColumn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <Button
                        android:id="@+id/btnRightClick"
                        android:layout_width="48dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_outline"
                        android:text="R"
                        android:textColor="?attr/colorButtonIcon"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="3dp"
                        app:backgroundTint="@null" />

                    <Button
                        android:id="@+id/btnMiddleClick"
                        android:layout_width="48dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_outline"
                        android:text="M"
                        android:textColor="?attr/colorButtonIcon"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="3dp"
                        app:backgroundTint="@null" />

                    <Button
                        android:id="@+id/btnLeftClick"
                        android:layout_width="48dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_outline"
                        android:text="L"
                        android:textColor="?attr/colorButtonIcon"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        app:backgroundTint="@null" />

                </LinearLayout>

            </FrameLayout>

            <!-- ==============================================================
                 Center zone: switches between D-pad, Touchpad, Media panels
                 ============================================================== -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="260dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp">

                <!-- D-pad panel (shown in D-pad navigation mode) -->
                <RelativeLayout
                    android:id="@+id/layoutDpadPanel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="visible">

                    <!-- D-pad content — directional buttons + OK -->
                    <RelativeLayout
                        android:id="@+id/layoutDpad"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    <ImageButton
                        android:id="@+id/btnDpadUp"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_centerHorizontal="true"
                        android:layout_alignParentTop="true"
                        android:background="@drawable/bg_button"
                        android:src="@drawable/ic_arrow_up"
                        android:padding="12dp"
                        android:contentDescription="Up" />

                    <ImageButton
                        android:id="@+id/btnDpadDown"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_centerHorizontal="true"
                        android:layout_alignParentBottom="true"
                        android:background="@drawable/bg_button"
                        android:src="@drawable/ic_arrow_down"
                        android:padding="12dp"
                        android:contentDescription="Down" />

                    <ImageButton
                        android:id="@+id/btnDpadLeft"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true"
                        android:background="@drawable/bg_button"
                        android:src="@drawable/ic_arrow_left"
                        android:padding="12dp"
                        android:contentDescription="Left" />

                    <ImageButton
                        android:id="@+id/btnDpadRight"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true"
                        android:background="@drawable/bg_button"
                        android:src="@drawable/ic_arrow_right"
                        android:padding="12dp"
                        android:contentDescription="Right" />

                        <ImageButton
                            android:id="@+id/btnOk"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_centerInParent="true"
                            android:background="@drawable/bg_touchpad"
                            android:src="@drawable/ic_circle_dot"
                            android:padding="20dp"
                            android:contentDescription="OK" />

                    </RelativeLayout><!-- /layoutDpad -->

                </RelativeLayout><!-- /layoutDpadPanel -->

                <!-- Touchpad panel (shown in touchpad navigation mode) -->
                <FrameLayout
                    android:id="@+id/layoutTouchPanel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">

                    <!-- Touchpad content — area that detects finger movement -->
                    <FrameLayout
                        android:id="@+id/layoutTouchpad"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <FrameLayout
                            android:id="@+id/layoutTouchpadAlt"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_touchpad"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:id="@+id/lblSwipeToMove"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="Swipe to move&#10;Two fingers to scroll&#10;Tap to click"
                                android:textColor="?attr/colorButtonIcon"
                                android:textSize="12sp"
                                android:gravity="center" />

                        </FrameLayout><!-- /layoutTouchpadAlt -->

                </FrameLayout><!-- /layoutTouchpad -->

                </FrameLayout><!-- /layoutTouchPanel -->

                <!-- Media panel (fills full nav zone when side columns hidden) -->
                <LinearLayout
                    android:id="@+id/layoutMediaPanel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <!-- Row 1: RW | Prev | (gap) | Next | FF -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="0.6"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <ImageButton
                            android:id="@+id/btnMediaRW"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_button"
                            android:src="@drawable/ic_rewind"
                            android:padding="10dp"
                            android:contentDescription="Rewind"
                            android:layout_marginEnd="3dp" />

                        <Button
                            android:id="@+id/btnMediaPrev"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_button"
                            android:text="⏮"
                            android:textColor="?attr/colorButtonIcon"
                            android:textSize="18sp"
                            android:gravity="center"
                            android:layout_marginEnd="3dp"
                            app:backgroundTint="@null" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1" />

                        <Button
                            android:id="@+id/btnMediaNext"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_button"
                            android:text="⏭"
                            android:textColor="?attr/colorButtonIcon"
                            android:textSize="18sp"
                            android:gravity="center"
                            android:layout_marginStart="3dp"
                            app:backgroundTint="@null" />

                        <ImageButton
                            android:id="@+id/btnMediaFF"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_button"
                            android:src="@drawable/ic_fast_forward"
                            android:padding="10dp"
                            android:contentDescription="Fast Forward"
                            android:layout_marginStart="3dp" />

                    </LinearLayout>

                    <!-- Row 2: Large centered Play/Pause -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.5"
                        android:gravity="center">

                        <ImageButton
                            android:id="@+id/btnMediaPlayPause"
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:background="@drawable/bg_button_outline"
                            android:src="@drawable/ic_play_pause"
                            android:padding="18dp"
                            android:contentDescription="Play/Pause"
                            android:layout_gravity="center" />

                    </FrameLayout>

                    <!-- Row 3: Vol- | Mute | Vol+ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="0.6"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1" />

                        <ImageButton
                            android:id="@+id/btnMediaVolDown"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="2"
                            android:background="@drawable/bg_button"
                            android:src="@drawable/ic_volume_1"
                            android:padding="10dp"
                            android:contentDescription="Volume Down" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1" />

                        <ImageButton
                            android:id="@+id/btnMediaMute"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="2"
                            android:background="@drawable/bg_button"
                            android:src="@drawable/ic_volume_x"
                            android:padding="10dp"
                            android:contentDescription="Mute" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1" />

                        <ImageButton
                            android:id="@+id/btnMediaVolUp"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="2"
                            android:background="@drawable/bg_button"
                            android:src="@drawable/ic_volume_2"
                            android:padding="10dp"
                            android:contentDescription="Volume Up" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1" />

                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>

            <!-- Right column: Channel (dpad/media) / Scroll bar (touchpad) -->
            <FrameLayout
                android:id="@+id/layoutRightSide"
                android:layout_width="52dp"
                android:layout_height="match_parent">

                <!-- Channel buttons: Ch Up | Ch Down | Ch Entry -->
                <LinearLayout
                    android:id="@+id/layoutChColumn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:visibility="visible">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <ImageButton
                        android:id="@+id/btnChUp"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_button"
                        android:src="@drawable/ic_arrow_up"
                        android:padding="10dp"
                        android:contentDescription="Channel Up" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CH"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <ImageButton
                        android:id="@+id/btnChDown"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_button"
                        android:src="@drawable/ic_arrow_down"
                        android:padding="10dp"
                        android:contentDescription="Channel Down" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <FrameLayout
                        android:id="@+id/btnChEntry"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_button"
                        android:contentDescription="Channel Entry">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:gravity="center">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="1"
                                    android:textColor="?attr/colorButtonIcon"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:layout_marginEnd="3dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="2"
                                    android:textColor="?attr/colorButtonIcon"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3"
                                android:textColor="?attr/colorButtonIcon"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:gravity="center" />

                        </LinearLayout>

                    </FrameLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                </LinearLayout>

                <!-- Scroll bar (shown in touchpad mode) -->
                <FrameLayout
                    android:id="@+id/layoutScrollColumn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_button"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_scroll"
                        android:contentDescription="Scroll" />

                </FrameLayout>

            </FrameLayout>

        </LinearLayout>

        <!-- ==================================================================
             Row 3: Back | Home | Source
             ================================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button"
                android:src="@drawable/ic_arrow_left"
                android:padding="12dp"
                android:contentDescription="Back"
                android:layout_marginEnd="6dp" />

            <ImageButton
                android:id="@+id/btnHome"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button"
                android:src="@drawable/ic_home"
                android:padding="12dp"
                android:contentDescription="Home"
                android:layout_marginEnd="6dp" />

            <ImageButton
                android:id="@+id/btnSource"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button"
                android:src="@drawable/ic_monitor_play"
                android:padding="12dp"
                android:contentDescription="Source" />

        </LinearLayout>

        <!-- ==================================================================
             App Shortcuts: 2 rows of 3
             ================================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <ImageButton android:id="@+id/btnShortcut1"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1" android:background="@drawable/bg_button"
                    android:src="@drawable/youtube" android:padding="8dp"
                    android:scaleType="fitCenter" android:contentDescription="Shortcut 1"
                    android:tint="@null" android:layout_marginEnd="6dp" />

                <ImageButton android:id="@+id/btnShortcut2"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1" android:background="@drawable/bg_button"
                    android:src="@drawable/primevideo" android:padding="8dp"
                    android:scaleType="fitCenter" android:contentDescription="Shortcut 2"
                    android:tint="@null" android:layout_marginEnd="6dp" />

                <ImageButton android:id="@+id/btnShortcut3"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1" android:background="@drawable/bg_button"
                    android:src="@drawable/netflix" android:padding="8dp"
                    android:scaleType="fitCenter" android:contentDescription="Shortcut 3"
                    android:tint="@null" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageButton android:id="@+id/btnShortcut4"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1" android:background="@drawable/bg_button"
                    android:src="@drawable/disneyplus" android:padding="8dp"
                    android:scaleType="fitCenter" android:contentDescription="Shortcut 4"
                    android:tint="@null" android:layout_marginEnd="6dp" />

                <ImageButton android:id="@+id/btnShortcut5"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1" android:background="@drawable/bg_button"
                    android:src="@drawable/plex" android:padding="8dp"
                    android:scaleType="fitCenter" android:contentDescription="Shortcut 5"
                    android:tint="@null" android:layout_marginEnd="6dp" />

                <ImageButton android:id="@+id/btnShortcut6"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1" android:background="@drawable/bg_button"
                    android:src="@drawable/kodi" android:padding="8dp"
                    android:scaleType="fitCenter" android:contentDescription="Shortcut 6"
                    android:tint="@null" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorDivider"
            android:layout_marginBottom="8dp"
            android:alpha="0.4" />

        <!-- ==================================================================
             Utility Row A: Apps | Cast | Keyboard
             ================================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <ImageButton
                android:id="@+id/btnApps"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:background="@drawable/bg_button"
                android:src="@drawable/ic_grid_2x2" android:padding="10dp"
                android:contentDescription="Apps" android:layout_marginEnd="3dp" />

            <ImageButton
                android:id="@+id/btnCast"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:background="@drawable/bg_button"
                android:src="@drawable/ic_cast" android:padding="10dp"
                android:contentDescription="Cast" android:layout_marginHorizontal="3dp" />

            <ImageButton
                android:id="@+id/btnKeyboard"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:background="@drawable/bg_button"
                android:src="@drawable/ic_keyboard" android:padding="10dp"
                android:contentDescription="Keyboard" android:layout_marginHorizontal="3dp" />

        </LinearLayout>

        <!-- ==================================================================
             Utility Row B: Media | Voice | Toggle Nav Mode
             ================================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <ImageButton
                android:id="@+id/btnMediaToggle"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:background="@drawable/bg_button"
                android:src="@drawable/ic_play_pause" android:padding="10dp"
                android:contentDescription="Media" android:layout_marginEnd="3dp" />

            <ImageButton
                android:id="@+id/btnVoice"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:background="@drawable/bg_button"
                android:src="@drawable/ic_mic" android:padding="10dp"
                android:contentDescription="Voice Command" android:layout_marginHorizontal="3dp" />

            <ImageButton
                android:id="@+id/btnToggleNavMode"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:background="@drawable/bg_button"
                android:src="@drawable/ic_tv_minimal" android:padding="10dp"
                android:contentDescription="Toggle Nav Mode" android:layout_marginStart="3dp" />

        </LinearLayout>

        <!-- ==================================================================
             Scroll strip area (for touchpad scroll two-finger gesture)
             ================================================================== -->
        <View
            android:id="@+id/scrollStrip"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="?attr/colorDivider"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
