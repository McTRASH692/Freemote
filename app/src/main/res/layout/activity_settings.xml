<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_button"
                android:src="@drawable/ic_arrow_left"
                android:padding="12dp"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <View android:layout_width="48dp" android:layout_height="48dp" />
        </LinearLayout>

        <!-- Theme Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="THEME"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_button"
            android:padding="12dp"
            android:layout_marginBottom="24dp">

            <Spinner
                android:id="@+id/spinnerTheme"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button"
                android:text="Save Theme"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- App Shortcut Slots -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APP SHORTCUT SLOTS"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_button"
            android:padding="12dp"
            android:layout_marginBottom="24dp">

            <!-- Slot 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Slot 1"
                    android:textColor="?attr/colorTextPrimary" android:textSize="14sp" />
                <Spinner android:id="@+id/spinnerSlot1"
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="2" />
            </LinearLayout>

            <!-- Slot 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Slot 2"
                    android:textColor="?attr/colorTextPrimary" android:textSize="14sp" />
                <Spinner android:id="@+id/spinnerSlot2"
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="2" />
            </LinearLayout>

            <!-- Slot 3 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Slot 3"
                    android:textColor="?attr/colorTextPrimary" android:textSize="14sp" />
                <Spinner android:id="@+id/spinnerSlot3"
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="2" />
            </LinearLayout>

            <!-- Slot 4 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Slot 4"
                    android:textColor="?attr/colorTextPrimary" android:textSize="14sp" />
                <Spinner android:id="@+id/spinnerSlot4"
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="2" />
            </LinearLayout>

            <!-- Slot 5 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Slot 5"
                    android:textColor="?attr/colorTextPrimary" android:textSize="14sp" />
                <Spinner android:id="@+id/spinnerSlot5"
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="2" />
            </LinearLayout>

            <!-- Slot 6 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Slot 6"
                    android:textColor="?attr/colorTextPrimary" android:textSize="14sp" />
                <Spinner android:id="@+id/spinnerSlot6"
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="2" />
            </LinearLayout>

        </LinearLayout>

        <!-- Touchpad Sensitivity -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TOUCHPAD SENSITIVITY"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_button"
            android:padding="12dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sensitivity"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvSensitivityValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.0x"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="13sp" />

            </LinearLayout>

            <SeekBar
                android:id="@+id/seekSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="40"
                android:progress="15" />

        </LinearLayout>

        <!-- Device Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DEVICE LABEL"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_button"
            android:padding="12dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Device label"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="11sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etDeviceLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="14sp"
                android:background="@null"
                android:hint="e.g. Living Room TV"
                android:textColorHint="?attr/colorTextSecondary"
                android:inputType="text" />

        </LinearLayout>

        <!-- Port Settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_button"
            android:padding="12dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Default port"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvPortValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8002 (WSS)"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="13sp"
                android:layout_marginEnd="8dp" />

            <Switch
                android:id="@+id/switchPort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Clear Pairing -->
        <Button
            android:id="@+id/btnClearPairing"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_button"
            android:text="Clear saved pairing / token"
            android:textColor="?attr/colorDangerButton"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
