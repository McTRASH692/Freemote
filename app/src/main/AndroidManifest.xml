<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- Location permissions -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- System permissions -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- Storage permissions -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- Media / projection -->
    <uses-permission android:name="android.permission.MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAPTURE_VIDEO_OUTPUT" />
    <uses-permission android:name="android.permission.CAPTURE_SECURE_VIDEO_OUTPUT" />

    <!-- Media access -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- Misc -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Bluetooth -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Nearby devices -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher_remote"
        android:label="Freemote"
        android:supportsRtl="true"
        android:theme="@style/Theme_Freemote"
        android:requestLegacyExternalStorage="true"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- ============================================================
             DeviceDiscoveryActivity — The first screen the user sees.
             Scans the local network for TVs running the remote server,
             lists them, and lets the user pick one or enter an IP.
             This is the LAUNCHER activity (app starts here).
             ============================================================ -->
        <activity
            android:name=".ui.DeviceDiscoveryActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ============================================================
             RemoteActivity — The main remote control screen. Shows all
             the buttons (power, volume, D-pad, touchpad, etc.) after
             the user has connected to a TV.
             ============================================================ -->
        <activity android:name=".ui.RemoteActivity" android:exported="false" />

        <!-- ============================================================
             SettingsActivity — App settings screen where the user can
             configure preferences like theme selection, connection
             settings, and other options.
             ============================================================ -->
        <activity android:name=".ui.SettingsActivity" android:exported="false" />

        <!-- ============================================================
             DeviceManagementActivity — Shows a list of saved TV devices
             that the user has previously connected to.
             ============================================================ -->
        <activity android:name=".ui.DeviceManagementActivity" android:exported="false" />

        <!-- ============================================================
             DeviceEditActivity — Lets the user edit or add a TV device's
             connection details (name, IP address, port).
             ============================================================ -->
        <activity android:name=".ui.DeviceEditActivity" android:exported="false" />

        <!-- ============================================================
             CustomThemeActivity — Lets the user create custom color
             themes by picking their own colors for each part of the UI.
             ============================================================ -->
        <activity android:name=".ui.CustomThemeActivity" android:exported="false" />

        <!-- ============================================================
             VoiceCommandActivity — A translucent overlay activity that
             listens for voice commands. The user can speak commands
             (like "volume up", "mute") instead of pressing buttons.
             ============================================================ -->
        <activity
            android:name=".ui.VoiceCommandActivity"
            android:exported="false"
            android:theme="@style/Theme_AppCompat_Translucent" />

        <!-- ============================================================
             SERVICES — Background processes that run even when the
             activity is not in the foreground.
             ============================================================ -->

        <!-- ============================================================
             MouseCursorService — Draws a mouse cursor overlay on the
             screen when the user is using touchpad mode on the remote.
             ============================================================ -->
        <service
            android:name=".ui.MouseCursorService"
            android:exported="false" />

        <!-- ============================================================
             RemoteService — The main background service that maintains
             the WebSocket / network connection to the TV, so the remote
             stays connected even if the UI is minimized.
             ============================================================ -->
        <service
            android:name=".RemoteService"
            android:foregroundServiceType="connectedDevice"
            android:exported="false" />

        <!-- ============================================================
             ScreenCastingService — Handles capturing the device screen
             and streaming it to the TV (screen mirroring / casting).
             ============================================================ -->
        <service
            android:name=".ScreenCastingService"
            android:foregroundServiceType="mediaProjection"
            android:exported="false" />

    </application>

</manifest>
